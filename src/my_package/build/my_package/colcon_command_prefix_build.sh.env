for qt_plugins in \
  /nix/store/i282hl3017jbvqzp38mhl3vzyhkkc8xs-qtbase-5.15.17-bin/lib/qt-*/plugins \
  /nix/store/fcxay86p8rzpky81h2i1f9yg8hp2clkj-qtwayland-5.15.17-bin/lib/qt-*/plugins
do
